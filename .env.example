# Application Settings
APP_NAME=DataDotMD
ROOT_DIRECTORY_NAME=Root
APP_BASE_URL=http://localhost:8000
DEBUG=False

# Data Directory
DATA_ROOT=./data

# Database
DATABASE_URL=sqlite:///./datadotmd.db

# Pagination
ITEMS_PER_PAGE=10

# Auto-Scan Settings
# Enable automatic directory scanning in the background
ENABLE_AUTO_SCAN=False
# Interval in minutes between automatic scans
AUTO_SCAN_INTERVAL_MINUTES=60
